# Copy this file to .env for local development.
# Do not commit real secrets.

# Required for live NVIDIA NIM topic/question generation.
NVIDIA_API_KEY=your_nvidia_nim_key_here

# Optional. Defaults to google/gemma-2-27b-it when unset.
NIM_MODEL=google/gemma-2-27b-it

# Optional local server port. Railway sets PORT automatically.
PORT=4173

# Optional production database. Railway PostgreSQL provides DATABASE_URL.
# DATABASE_URL=postgresql://user:password@host:5432/database
# DATABASE_SSL=true
